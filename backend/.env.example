# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/commuto

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration (comma-separated list of allowed origins)
# For production, set this to your frontend URL(s)
CORS_ALLOW_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate Limiting
# Redis URL for distributed rate limiting (optional, defaults to in-memory)
REDIS_URL=redis://localhost:6379/0

# Environment
ENVIRONMENT=development

# Razorpay Configuration
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Frontend URL (used to build verification link)
FRONTEND_URL=http://localhost:3000

# SMTP Email Verification (primary)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# EmailJS Email Verification (fallback)
# Provided values from your account:
EMAILJS_SERVICE_ID=service_wu86z4p
EMAILJS_TEMPLATE_ID=template_dfq9mib
# Required: EmailJS public key (User ID)
EMAILJS_PUBLIC_KEY=
# Optional: EmailJS private key (access token)
EMAILJS_PRIVATE_KEY=
